{
  "title": "Universal Useful Snippets",
  "url": "https://github.com/MinhCreator/useful-snippets",
  "src": "docs",
  "out": "site",
  "engine": "js",
  "layout": {
    "spa": true,
    "header": {
      "enabled": true
    },
    "sidebar": {
      "collapsible": true,
      "defaultCollapsed": true
    },
    "optionsMenu": {
      "position": "sidebar-top",
      "components": {
        "search": true,
        "themeSwitch": true
      }
    },
    "footer": {
      "style": "minimal",
      "content": "© 2026 MinhCreatorVN.",
      "branding": true
    }
  },
  "theme": {
    "name": "default",
    "appearance": "system",
    "codeHighlight": true
  },
  "minify": true,
  "autoTitleFromH1": true,
  "copyCode": true,
  "pageNavigation": true,
  "navigation": [
    { "title": "Introduction", "path": "/", "icon": "home" },
    
    {
      "title": "Snippets",
      "path": "/snippets",
      "icon": "code",
      "collapsible": true,
      "children": []
    },
    {
      "title": "GitHub",
      "path": "https://github.com/MinhCreator/useful-snippets",
      "icon": "github",
      "external": true
    }
  ],
  "plugins": {
    "git": {
      "commitHistory": true,
      "maxCommits": 5
    },
    "seo": {
      "defaultDescription": "Documentation built with docmd."
    }
  }
}
